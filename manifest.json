{
    "manifest_version": 3,
    "name": "OverLook",
    "version": "1.0",
    "description": "Capture screenshots and overlay them on the page with adjustable opacity, rotation, and size.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_title": "Toggle Overlay Panel"
    },
    "background": {
        "service_worker": "src/background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}